# ── Required ─────────────────────────────────────────────────────────────────
# Finnhub API Key — free tier at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Flask ────────────────────────────────────────────────────────────────────
# Random string used to sign session cookies — change before deploying!
SECRET_KEY=change-me-before-deploying

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "ollama" (local) or "gemini" (Google Cloud)
LLM_PROVIDER=ollama

# Ollama (local) — default
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=gemma3:latest

# Gemini (optional — requires GOOGLE_API_KEY)
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key_here

# ── Cache ────────────────────────────────────────────────────────────────────
# TTL values in seconds (defaults shown)
QUOTE_CACHE_TTL=300
NEWS_CACHE_TTL=600
HISTORY_CACHE_TTL=180
ANALYSIS_CACHE_TTL=600
